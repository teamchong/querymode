{
  "name": "querymode",
  "version": "0.1.0",
  "description": "Serverless columnar query engine on Cloudflare Durable Objects",
  "type": "module",
  "bin": {
    "querymode": "src/cli/init.ts"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./local": {
      "import": "./dist/local.js",
      "types": "./dist/local.d.ts"
    }
  },
  "scripts": {
    "dev": "wrangler dev",
    "prepublishOnly": "pnpm run build",
    "build": "pnpm run build:wasm && pnpm run build:ts",
    "build:wasm": "cd wasm && zig build wasm && mkdir -p ../src/wasm && cp zig-out/bin/querymode.wasm ../src/wasm/",
    "build:ts": "tsc && mkdir -p dist/wasm && cp src/wasm/querymode.wasm dist/wasm/",
    "test": "vitest run -c vitest.workers.config.ts && vitest run",
    "test:workers": "vitest run -c vitest.workers.config.ts",
    "test:node": "vitest run",
    "test:quick": "vitest run -c vitest.workers.config.ts src/convenience.test.ts src/format.test.ts src/footer.test.ts src/decode.test.ts src/merge.test.ts src/partial-agg.test.ts src/vip-cache.test.ts src/page-processor.test.ts src/sql/lexer.test.ts src/sql/parser.test.ts src/sql/compiler.test.ts src/sql/evaluator.test.ts src/sql/integration.test.ts",
    "test:watch": "vitest",
    "deploy": "pnpm run build && wrangler deploy",
    "wasm": "pnpm run build:wasm",
    "bench:seed": "npx tsx scripts/seed-local-r2.ts",
    "bench": "npx tsx scripts/bench.ts",
    "bench:operators": "vitest bench src/bench-vs-duckdb.bench.ts",
    "bench:local": "npx tsx scripts/bench-local.ts"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.20",
    "@cloudflare/workers-types": "^4.20250224.0",
    "@types/node": "^25.3.3",
    "duckdb": "^1.4.4",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  },
  "files": [
    "dist",
    "src/wasm/querymode.wasm"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.21.0",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "duckdb"
    ],
    "overrides": {
      "tar": ">=7.5.10",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "@tootallnate/once": ">=3.0.1"
    }
  }
}
