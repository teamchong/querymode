{
  "name": "querymode",
  "version": "0.1.0",
  "description": "Serverless columnar query engine on Cloudflare Durable Objects",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./local": {
      "import": "./dist/local.js",
      "types": "./dist/local.d.ts"
    }
  },
  "scripts": {
    "dev": "wrangler dev",
    "prepublishOnly": "pnpm run build",
    "build": "pnpm run build:wasm && pnpm run build:ts",
    "build:wasm": "cd wasm && zig build wasm && mkdir -p ../src/wasm && cp zig-out/bin/querymode.wasm ../src/wasm/",
    "build:ts": "tsc && mkdir -p dist/wasm && cp src/wasm/querymode.wasm dist/wasm/",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "pnpm run build && wrangler deploy",
    "wasm": "pnpm run build:wasm",
    "bench:seed": "npx tsx scripts/seed-local-r2.ts",
    "bench": "npx tsx scripts/bench.ts",
    "bench:operators": "vitest bench src/bench-vs-duckdb.bench.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250224.0",
    "@types/node": "^25.3.3",
    "duckdb": "^1.4.4",
    "miniflare": "^4.20260301.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  },
  "files": [
    "dist",
    "src/wasm/querymode.wasm"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.21.0",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "duckdb"
    ],
    "overrides": {
      "tar": ">=7.5.10",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "@tootallnate/once": ">=3.0.1"
    }
  }
}
