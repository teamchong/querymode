{
  "name": "querymode",
  "version": "0.1.0",
  "description": "Serverless columnar query engine on Cloudflare Durable Objects",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "wrangler deploy",
    "wasm": "cd wasm && zig build wasm && cp zig-out/bin/querymode.wasm ../src/wasm/",
    "bench:seed": "npx tsx scripts/seed-local-r2.ts",
    "bench": "npx tsx scripts/bench.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250224.0",
    "@types/node": "^25.3.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  },
  "files": [
    "dist",
    "src/wasm/querymode.wasm"
  ],
  "license": "MIT"
}
